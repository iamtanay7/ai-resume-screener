# Google Cloud project
GCP_PROJECT_ID=your-project-id

# Cloud Storage bucket for raw uploads
GCS_BUCKET_RAW=resume-screener-raw

# Pub/Sub topics
PUBSUB_TOPIC_RESUME=resume-uploaded
PUBSUB_TOPIC_JD=jd-uploaded

# Max file size in bytes (10 MB default)
MAX_FILE_SIZE_BYTES=10485760

# CORS origins — comma-separated (local dev + Cloud Run)
CORS_ORIGIN=http://localhost:3000

# Path to GCP service account key JSON (local dev only)
# Leave empty when running on Cloud Run (uses workload identity)
GOOGLE_APPLICATION_CREDENTIALS=

# ── Ranking engine (Michael) ─────────────────────────────────────────────────
# Weights must sum to 1.0
RANKING_WEIGHT_SKILLS=0.4
RANKING_WEIGHT_EXPERIENCE=0.3
RANKING_WEIGHT_EDUCATION=0.15
RANKING_WEIGHT_KEYWORDS=0.15

# Score thresholds for decision buckets (0–100 scale)
RANKING_THRESHOLD_SHORTLIST=75.0
RANKING_THRESHOLD_MANUAL_REVIEW=55.0

# Version tag written to each ranked candidate doc
RANKING_VERSION=v1
