# Google Cloud project
GCP_PROJECT_ID=your-project-id

# Cloud Storage bucket for raw uploads
GCS_BUCKET_RAW=resume-screener-raw

# Pub/Sub topics
PUBSUB_TOPIC_RESUME=resume-uploaded
PUBSUB_TOPIC_JD=jd-uploaded

# Max file size in bytes (10 MB default)
MAX_FILE_SIZE_BYTES=10485760

# CORS origin — your Next.js frontend URL
CORS_ORIGIN=http://localhost:3000

# Path to GCP service account key JSON (local dev only)
# Leave empty when running on Cloud Run (uses workload identity)
GOOGLE_APPLICATION_CREDENTIALS=
